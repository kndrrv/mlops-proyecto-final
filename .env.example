# Variables de entorno — copia este archivo a .env y completa los valores
# NUNCA subas el .env real a GitHub

# ── LLM (Groq — gratis en console.groq.com) ──────────────────────────────────
GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=300

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=mlops-proyecto-final

# ── Rutas del modelo ──────────────────────────────────────────────────────────
MODEL_PATH=models/model.pkl
ENCODER_PATH=models/label_encoder.pkl
DATA_PATH=data/dataset.csv
METRICS_PATH=metrics.json

# ── Entrenamiento ─────────────────────────────────────────────────────────────
TEXT_COLUMN=text
TARGET_COLUMN=intent
TEST_SIZE=0.2
RANDOM_STATE=42
MAX_ITER=1000
C=5.0

# ── Reentrenamiento ───────────────────────────────────────────────────────────
PROMOTE_THRESHOLD=0.01
API_RELOAD_URL=http://localhost:8000/reload-model
CONFIDENCE_THRESHOLD=0.4

